{{!
    @template local_kopere_sitemap/index

    Example context (json):
    {
      "title": "XML Sitemap",
      "description": "Manage and review your website sitemap configuration and availability.",
      "statuslabel": "Status",
      "statusvalue": "Active",
      "sitemapurllabel": "Sitemap URL",
      "sitemapurl": "https://example.com/sitemap.xml",
      "openxmllabel": "Open XML Sitemap",
      "items": [
        {
          "name": "Posts",
          "enabled": true
        },
        {
          "name": "Pages",
          "enabled": true
        },
        {
          "name": "Categories",
          "enabled": false
        },
        {
          "name": "Tags",
          "enabled": false
        }
      ]
    }
}}

<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h1 class="h3 mb-3">{{title}}</h1>
                    <p class="text-muted mb-4">{{description}}</p>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3">
                                <div class="small text-muted">{{statuslabel}}</div>
                                <div class="fw-semibold">{{statusvalue}}</div>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="p-3 bg-light rounded-3">
                                <div class="small text-muted">{{sitemapurllabel}}</div>
                                <div class="fw-semibold text-break">{{sitemapurl}}</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <a class="btn btn-primary" href="{{sitemapurl}}" target="_blank">{{openxmllabel}}</a>
                    </div>

                    <div class="list-group">
                        {{#items}}
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span>{{name}}</span>
                                {{#enabled}}
                                    <span class="badge text-bg-success">On</span>
                                {{/enabled}}
                                {{^enabled}}
                                    <span class="badge text-bg-secondary">Off</span>
                                {{/enabled}}
                            </div>
                        {{/items}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
